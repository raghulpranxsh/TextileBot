import requests
import os
import xml.etree.ElementTree as ET
from dotenv import load_dotenv

load_dotenv()

TALLY_HOST = os.getenv("TALLY_HOST", "127.0.0.1")
TALLY_PORT = os.getenv("TALLY_PORT", "9000")
TALLY_URL = f"http://{TALLY_HOST}:{TALLY_PORT}"

def parse_tally_xml(xml_string, target_tag):
    """
    Parses Tally XML response into a clean list of JSON-friendly dictionaries.
    """
    try:
        # Tally sometimes returns invalid XML characters like &#4;
        clean_xml = xml_string.replace("&#4;", "")
        root = ET.fromstring(clean_xml)
        results = []
        for node in root.findall(f".//COLLECTION/{target_tag}"):
            item = {}
            # If the tag has a NAME attribute (like STOCKITEM or LEDGER), extract it
            if 'NAME' in node.attrib:
                item['name'] = node.attrib['NAME']
            
            for child in node:
                # Extract text for direct child tags
                if len(child) == 0:
                    tag_name = child.tag.lower()
                    text_val = child.text.strip() if child.text else ""
                    if text_val: # Only include if it has value
                        item[tag_name] = text_val
            
            results.append(item)
        return results
    except ET.ParseError as e:
        return {"status": "error", "message": "Failed to parse XML response from Tally", "details": str(e)}
    except Exception as e:
        return {"status": "error", "message": "Unexpected error parsing XML", "details": str(e)}

def safe_tally_request(xml_request, target_tag):
    """
    Helper function to safely send request to Tally and handle exceptions.
    """
    try:
        return safe_tally_request(xml_request, "LEDGER")
        
        # Check if HTTP request itself failed
        if response.status_code != 200:
            return {"status": "error", "message": f"Tally server responded with error code {response.status_code}", "details": response.text}
            
        return parse_tally_xml(response.text, target_tag)
        
    except requests.exceptions.Timeout:
        return {"status": "error", "message": "Connection to Tally timed out. Is the PC running slow or network dropped?"}
    except requests.exceptions.ConnectionError:
        return {"status": "error", "message": "Failed to connect to Tally. Is Tally Prime open? Is the PC turned on?"}
    except requests.exceptions.RequestException as e:
        return {"status": "error", "message": "An error occurred while communicating with Tally.", "details": str(e)}
    except Exception as e:
        return {"status": "error", "message": "An unexpected error occurred in the connector.", "details": str(e)}

def get_stock_summary():

    xml_request = """
<ENVELOPE>
 <HEADER>
  <VERSION>1</VERSION>
  <TALLYREQUEST>Export</TALLYREQUEST>
  <TYPE>Collection</TYPE>
  <ID>StockItems</ID>
 </HEADER>
 <BODY>
  <DESC>
   <STATICVARIABLES>
    <SVEXPORTFORMAT>$$SysName:XML</SVEXPORTFORMAT>
   </STATICVARIABLES>
   <TDL>
    <TDLMESSAGE>
     <COLLECTION NAME="StockItems" ISMODIFY="No">
      <TYPE>Stock Item</TYPE>
      <FETCH>Name,OpeningBalance,ClosingBalance,BaseUnits</FETCH>
     </COLLECTION>
    </TDLMESSAGE>
   </TDL>
  </DESC>
 </BODY>
</ENVELOPE>
    """
    return safe_tally_request(xml_request, "STOCKITEM")

def get_outstanding():
    xml_request = """
<ENVELOPE>
 <HEADER>
  <VERSION>1</VERSION>
  <TALLYREQUEST>Export</TALLYREQUEST>
  <TYPE>Collection</TYPE>
  <ID>SundryDebtors</ID>
 </HEADER>
 <BODY>
  <DESC>
   <STATICVARIABLES>
    <SVEXPORTFORMAT>$$SysName:XML</SVEXPORTFORMAT>
   </STATICVARIABLES>
   <TDL>
    <TDLMESSAGE>
     <COLLECTION NAME="SundryDebtors" ISMODIFY="No">
      <TYPE>Ledger</TYPE>
      <CHILDOF>$$GroupSundryDebtors</CHILDOF>
      <BELONGSTO>Yes</BELONGSTO>
      <FETCH>Name,ClosingBalance,BillCreditPeriod</FETCH>
     </COLLECTION>
    </TDLMESSAGE>
   </TDL>
  </DESC>
 </BODY>
</ENVELOPE>
    """
    return safe_tally_request(xml_request, "LEDGER")

def get_invoices():
    xml_request = """
<ENVELOPE>
 <HEADER>
  <VERSION>1</VERSION>
  <TALLYREQUEST>Export</TALLYREQUEST>
  <TYPE>Collection</TYPE>
  <ID>SalesVouchers</ID>
 </HEADER>
 <BODY>
  <DESC>
   <STATICVARIABLES>
    <SVEXPORTFORMAT>$$SysName:XML</SVEXPORTFORMAT>
   </STATICVARIABLES>
   <TDL>
    <TDLMESSAGE>
     <COLLECTION NAME="SalesVouchers" ISMODIFY="No">
      <TYPE>Voucher</TYPE>
      <FETCH>Date,VoucherNumber,PartyLedgerName,Amount</FETCH>
      <FILTERS>IsSales</FILTERS>
     </COLLECTION>
     <SYSTEM TYPE="Formula" NAME="IsSales">$VoucherTypeName = "Sales"</SYSTEM>
    </TDLMESSAGE>
   </TDL>
  </DESC>
 </BODY>
</ENVELOPE>
    """
    return safe_tally_request(xml_request, "LEDGER")
